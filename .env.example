# === 聚合数据 (世界杯赛程) ===
# 注册: https://www.juhe.cn/
JUHE_API_KEY=your_juhe_api_key_here

# === LLM (OpenAI-compatible) ===
LLM_BASE_URL=https://your-llm-endpoint.com
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4

# === 飞书多维表格 ===
FEISHU_BASE_TOKEN=your_feishu_base_token_here
FEISHU_TABLE_ID=your_feishu_table_id_here

# === lark-cli ===
# 留空使用默认路径；自定义时填 lark-cli.cmd 的完整路径
LARK_CLI_PATH=

# === 飞书 Webhook (审核通知) ===
FEISHU_WEBHOOK_URL=

# === X (Twitter) 爬取 ===
# 从浏览器 Cookie 复制，格式: name1=value1; name2=value2
X_COOKIES=
CLASH_PORT=7892
X_BASE_URL=https://x.com
X_EXPLORE_URL=https://x.com/explore/tabs/trending

# === 输出控制 ===
DRY_RUN=true
OUTPUT_FORMAT=both
TIMEZONE=Asia/Shanghai
