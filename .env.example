# === 聚合数据 (世界杯赛程) ===
# 注册: https://www.juhe.cn/
JUHE_API_KEY=your_juhe_api_key_here

# === LLM (OpenAI-compatible) ===
LLM_BASE_URL=https://your-llm-endpoint.com
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4

# === X (Twitter) ===
X_COOKIES='your_x_cookies_here'
X_STORAGE_STATE_B64=

# === 飞书多维表格 ===
FEISHU_BASE_TOKEN=your_feishu_base_token_here
FEISHU_TABLE_ID=your_feishu_table_id_here

# === 飞书 Webhook (审核通知) ===
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# === 输出控制 ===
DRY_RUN=true
OUTPUT_FORMAT=both
TIMEZONE=Asia/Shanghai
DEBUG=false
